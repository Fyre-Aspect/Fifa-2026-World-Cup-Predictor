# Copy this file to `.env.local` and fill in your keys, then restart `npm run dev`.
# `.env.local` is gitignored; this template is safe to commit (no real secrets).
# Without any keys the app runs entirely on the bundled snapshot.

# football-data.org — free tier covers the FIFA World Cup (competition WC).
# Register free at https://www.football-data.org/client/register
# This is the primary live fixtures + scores source.
FOOTBALL_DATA_API_KEY=

# The Odds API — bookmaker consensus for the prediction model (optional).
# Register free at https://the-odds-api.com/
ODDS_API_KEY=

# API-Football (api-sports.io) — optional alternative live source with richer
# live data (live minute). https://www.api-football.com/
# API_FOOTBALL_KEY=
